# URL Web App Google Apps Script (setelah deploy)
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/AKfycbw7fzbwt2-BSf5ioUieemrrg6vbHlkjHutaBUYnLPMyqtg6KiRamC3Nz3qrW-ZoNd-X/exec

# Nomor admin WhatsApp untuk redirect dinamis setelah submit (hanya digit, tanpa + / spasi / -)
VITE_WHATSAPP_ADMIN_PHONE=6285188438643

# Legacy fallback only. Prefer VITE_WHATSAPP_ADMIN_PHONE for dynamic WhatsApp message.
VITE_WHATSAPP_REDIRECT_URL=https://api.whatsapp.com/send/?phone=628XXXXXXXXXX&text=Halo%20Admin%20TEKAD%2C%20saya%20sudah%20daftar%20webinar.%20Mohon%20info%20jadwal%20dan%20grup%20webinarnya.&type=phone_number&app_absent=0

# Token rahasia — harus sama dengan FORM_TOKEN di Google Apps Script Script Properties
VITE_FORM_TOKEN=your-secret-token-here