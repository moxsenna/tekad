# URL Web App Google Apps Script (setelah deploy)
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# URL redirect WhatsApp setelah submit berhasil
# Format: https://wa.me/628XXXXXXXXXX?text=Pesan%20prefill%20di%20sini
VITE_WHATSAPP_REDIRECT_URL=https://wa.me/628XXXXXXXXXX?text=Halo%20Admin%20TEKAD%2C%20saya%20sudah%20daftar%20webinar%20Dari%20Bingung%20Arah%20Menjadi%20Siap%20Kerja.%20Mohon%20info%20jadwal%20dan%20grup%20webinarnya.

# Token rahasia — harus sama dengan FORM_TOKEN di Google Apps Script Script Properties
VITE_FORM_TOKEN=your-secret-token-here